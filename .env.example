# Copy this file to .env and fill in your values.
# Never commit .env to version control.

STORYFORGE_GEMINI_API_KEY=your_google_ai_studio_key

# Google OAuth (from Google Cloud Console → Credentials → OAuth 2.0 Client IDs)
STORYFORGE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
STORYFORGE_GOOGLE_CLIENT_SECRET=your_client_secret

# JWT signing secret — change this to a long random string in production
STORYFORGE_JWT_SECRET=change-me-in-production

# Allowed CORS origins — space-separated. Add your ngrok URL each session.
STORYFORGE_ALLOWED_ORIGINS=http://localhost:8765 http://127.0.0.1:8765
